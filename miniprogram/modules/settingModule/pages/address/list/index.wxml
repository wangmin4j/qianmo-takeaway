<!--pages/address/list/index.wxml1-->

<view class="container address-list" bind:tap="onSwipeCellPage">
  <view class="list-warpper" wx:if="{{ addressList.length > 0 ? true : false }}">
    <view wx:for="{{ addressList }}" wx:key="id" class="list-item">
      <van-swipe-cell id="swipe-cell-{{item.id}}" bind:open="swipeCellOpen" bind:click="onSwipeCellClick" right-width="{{ 65 }}">
        <van-cell-group border="{{ false }}">
          <view class="list-item-box">
            <view class="info" bind:tap="changeAddress" data-id="{{item.id}}">
              <view class="user-info">
                <text>{{item.consignee}}</text>
                <text>{{item.sex === '0' ? '先生' : '女士'}}</text>
                <text>{{item.phone}}</text>
                <text class="default-tag" wx:if="{{item.isDefault === 1 ? true : false}}">默认</text>
              </view>

              <view class="address-info">
                {{item.provinceName + item.cityName + item.districtName + item.detail + ' '}}
                <text class="default-tag-label">{{labelArray[item.label]}}</text>
              </view>
            </view>

            <view class="editBtn" bindtap="toEdit" data-id="{{item.id}}">
              <van-icon name="edit" size="22px" color="#999" />
            </view>
          </view>
        </van-cell-group>
        <!-- <van-icon name="delete" size="22px" color="#999" /> -->
        <view 
        slot="right" 
        class="van-swipe-cell__right" 
        bind:tap="delAddress"
        data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </van-swipe-cell>
    </view>
  </view>

  <van-empty wx:else description="还没有收货地址，快去添加吧～" />

  <view class="footer">
    <view class="btn">
      <navigator url="/modules/settingModule/pages/address/add/index">
        新增地址
      </navigator>
    </view>
  </view>
</view>
