<!--pages/order/list/index.wxml-->
<view class="order-container container">
  <view class="order-list" wx:if="{{ orderList.length > 0 }}" >
    <view class="order-item" wx:for="{{ orderList }}" wx:key="id">
      <view class="order-item-header list-flex">
        <view class="orderno">订单号<text class="no">{{item.number}}</text></view>
        <view class="order-status">{{statusArr[item.status]}}</view>
      </view>
      <view class="goods-item list-flex"  >
        <view class="left">
          <image src="{{item.orderDetailList[0].image}}" mode="widthFix" class="img" />
        </view>
        <block wx:for="{{item.orderDetailList}}" wx:key="id" wx:for-item="i" >
        <block wx:if="{{index < 3}}">
        <view class="mid">
          <view class="goods-name">{{i.name}}</view>
        </view>
        <view class="right">
          <view class="goods-price">¥{{i.amount}} x{{i.number}}</view>
        </view>
      </block>
        </block>
      </view>
      <view class="order-item-footer">
        <view class="total-amount list-flex">
          <text class="text">实付</text>
          <text class="price"><text>¥</text> {{item.amount}}</text>
        </view>
      </view>
    </view>
  </view>
  <van-empty wx:else description="还没有购买商品，快去购买吧～" />
</view>
