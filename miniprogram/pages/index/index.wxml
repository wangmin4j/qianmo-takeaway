<!-- 骨架屏 -->
<import src="./skeleton/index.skeleton.wxml"/>
<!-- 使用骨架屏幕 -->
<template is="skeleton" wx:if="{{loading}}" />

<view wx:else class="index-container">
  <!--首页背景图-->
  <view class="window-bgc"></view>

  <!-- 页面主体区域 -->
  <view class="container">
    <!-- 轮播图区域 -->
    <banner bannerList="{{bannerList}}" />

    <!-- 导航分类 -->
    <entrance cateList="{{cateList}}" />

    <!-- 广告区域 -->
    <view class="adver">
      <view class="adver-left">
        <navigator url="/modules/goodModule/pages/goods/detail/detail?id={{activeListList[0].id}}">
          <image  src="{{activeListList[0].image}}" mode="widthFix" />
        </navigator>
      </view>

      <view class="adver-right">
        <view>
          <navigator url="/modules/goodModule/pages/goods/detail/detail?id={{activeListList[1].id}}">
            <image src="{{activeListList[1].image}}" mode="widthFix" />
          </navigator>
        </view>
        <view>
          <navigator url="/modules/goodModule/pages/goods/detail/detail?id={{activeListList[2].id}}">
            <image src="{{activeListList[2].image}}" mode="widthFix" />
          </navigator>
        </view>
      </view>
    </view>

    <!-- 商品列表 -->
    <!-- <goods-list title="猜你喜欢"></goods-list> -->
    <goods-list title="人气推荐" list="{{hotList}}"></goods-list>
  </view>
</view>
