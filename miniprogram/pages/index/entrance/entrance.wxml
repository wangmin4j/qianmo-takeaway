<view class="nav-list">
  <!-- 一级分类导航容器 -->
  <view
    wx:for="{{ cateList }}"
    wx:key="index"
    class="nav-item {{ index >= 5 ? 'small' : '' }}"
  >
    <!-- 导航链接 -->
    <navigator class="navigator-nav" url="/modules/goodModule/pages/goods/list-setmeal/list?id={{item.id}}">
      <image class="nav-img" src="{{item.image}}" />
      <text class="nav-text">{{item.name}}</text>
    </navigator>
  </view>
</view>
